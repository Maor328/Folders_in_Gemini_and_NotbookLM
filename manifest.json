{
  "manifest_version": 3,
  "name": "Gemini & NotebookLM Folders",
  "version": "1.0.1",
  "description": "A productivity extension that integrates custom, color-coded folders directly into NotebookLM and Gemini for better organization.",
  "permissions": ["storage"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    },
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": ["NotebookLM-content.js"],
      "css": ["styles.css"]
    }
  ]
}
